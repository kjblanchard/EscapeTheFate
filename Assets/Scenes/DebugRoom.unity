--- !u!114 &1635222497
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1635222496}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d826f049982a0f441b81c402053d10c0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialog:
    dialogLines:
    - npc-
    - Have you ever played Triple Triad Before?
    - t-
    - I don't think so, looks pretty lame to me.
    - 'npc- '
    - Bah, don't be a hater.  Go ahead and challenge me by pressing X and we can go.
    - 't- '
    - I'm trying, but it won't let me play you.
    - k-
    - Only the actual important characters in the game can play cards, Duh!
    - npc-
    - ". . . . . . \n*Can hear crickets chirping*\nJust press X to play."
  isPerson: 1
  isSaveCrystal: 0
  afterBattleDialogWin:
    dialogLines:
    - Wow, I lost to a total rookie.  Noice
  afterBattleDialogDraw:
    dialogLines:
    - You gotta learn to play a little better.
  afterBattleDialogLose:
    dialogLines:
    - Straight Garbage bra
  npcName: Hat Creep
  npcSprite: {fileID: 21300000, guid: 81afc216df600e443a0dd806e534d1e8, type: 3}
  showPortrait: 1
  showName: 1
